# =============================================================================
# SAS Restaurantes — Variables de Entorno
# Copiar a .env y completar con valores reales. Nunca commitear .env
# =============================================================================

# --- API ---
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://sas:sas_password@db:5432/sas_restaurante
REDIS_URL=redis://redis:6379
JWT_SECRET=change_this_to_a_random_secret_in_production

# --- Culqi (Pagos) ---
CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=

# --- Frontend ---
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_CULQI_PUBLIC_KEY=

# --- pgAdmin (solo dev) ---
PGADMIN_DEFAULT_EMAIL=admin@sas.local
PGADMIN_DEFAULT_PASSWORD=admin
